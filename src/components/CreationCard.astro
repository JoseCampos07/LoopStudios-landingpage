---
const { image_desktop, image_mobile, title } = Astro.props;
---

<div class="relative w-140 md:w-60">
    <img src={ image_desktop } alt={ title } class="hidden md:block md:brightness-75 md:transition md:duration-300 md:ease-in-out hover:contrast-50">
    <img src={ image_mobile } alt={ title } class="md:hidden">

    <h1 class="absolute bottom-2 left-2 max-w-50 text-4xl text-white font-light ml-2 mb-2 md:text-3xl md:max-w-40">
        { title }
    </h1>
</div>